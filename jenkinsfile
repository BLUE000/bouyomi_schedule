pipeline {
    agent any
    
    parameters {
        string(name: 'BRANCH_NAME', defaultValue: 'master', description: 'ビルド対象のブランチ名')
        choice(name: 'BUILD_TYPE', choices: ['individual', 'periodic'], description: 'ビルドタイプ（通知先の切り替え）')
    }
    
    environment {
        WEBHOOK_INDIVIDUAL = credentials('discord-webhook-individual')
        WEBHOOK_PERIODIC = credentials('discord-webhook-periodic')
    }
    
    stages {
        stage('Checkout') {
            steps {
                echo "ブランチ ${params.BRANCH_NAME} をチェックアウト中..."
                git branch: "${params.BRANCH_NAME}",
                    url: 'https://github.com/BLUE000/bouyomi_schedule.git'
            }
        }
        
        stage('Build') {
            steps {
                echo 'CMakeでビルド中...'
                sh '''
                    mkdir -p build
                    cd build
                    cmake ..
                    cmake --build .
                '''
            }
        }
        
        stage('Notify Discord') {
            steps {
                script {
                    def webhook = params.BUILD_TYPE == 'individual' ? env.WEBHOOK_INDIVIDUAL : env.WEBHOOK_PERIODIC
                    sh """
                        curl -X POST ${webhook} \
                        -H "Content-Type: application/json" \
                        -d '{"content": "✅ ビルド成功: ${params.BRANCH_NAME} (${params.BUILD_TYPE})"}'
                    """
                }
            }
        }
    }
    
    post {
        failure {
            script {
                def webhook = params.BUILD_TYPE == 'individual' ? env.WEBHOOK_INDIVIDUAL : env.WEBHOOK_PERIODIC
                sh """
                    curl -X POST ${webhook} \
                    -H "Content-Type: application/json" \
                    -d '{"content": "❌ ビルド失敗: ${params.BRANCH_NAME} (${params.BUILD_TYPE})"}'
                """
            }
        }
    }
}
